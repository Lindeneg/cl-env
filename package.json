{
    "name": "clenv",
    "version": "1.0.0",
    "description": "Type-safe, leak-free environment variable loader",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.mts",
                "default": "./dist/index.mjs"
            },
            "require": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.js"
            }
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "prepublishOnly": "npm run test && npm run build",
        "build": "tsc -p tsconfig.build.json",
        "test": "npm run test:impl && npm run test:types",
        "test:impl": "vitest run",
        "test:types": "tsc --noEmit"
    },
    "keywords": [
        "javascript",
        "typescript",
        "env",
        "dotenv",
        "environment",
        "variables",
        "type-safety"
    ],
    "author": "Christian Lindeneg",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/lindeneg/clenv.git"
    },
    "homepage": "https://github.com/lindeneg/clenv#readme",
    "license": "MIT",
    "devDependencies": {
        "@types/node": "25.3.5",
        "type-testing": "0.2.0",
        "typescript": "5.9.3",
        "vitest": "4.0.18"
    }
}
